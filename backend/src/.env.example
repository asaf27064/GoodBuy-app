# Copy to backend/src/.env and fill in real values for local dev.
# For production, set these on your hosting provider (Render, Fly, etc.) —
# never commit the real .env.

# MongoDB connection string. In docker-compose, this is overridden to
# mongodb://mongo:27017/goodbuy automatically.
MONGO_URI=mongodb://localhost:27017/goodbuy

# JWT secrets — generate long random strings, NOT these placeholders.
# e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# Gemini API key for the recommendation engine's LLM tie-break + suggestions.
# Recommendations still work without it (rule-based fallback) but with less
# variety.
GEMINI_API_KEY=

# Comma-separated list of allowed CORS origins for the API. Leave empty in
# local dev to allow all; in production, set to your mobile/web origin(s).
ALLOWED_ORIGINS=

# Optional: override the API port (default 3000).
PORT=3000
